{
  "$schema": "https://opencode.ai/config.json",
  "model": "openai/gpt-5.4",
  "small_model": "openai/gpt-5.4-mini",
  "autoupdate": "notify",
  "share": "off",
  "default_agent": "build",
  "permission": {
    "edit": "allow",
    "bash": {
      "*": "allow",
      "rm -rf*": "deny",
      "git push --force*": "deny",
      "git reset --hard*": "deny",
      "npm publish*": "deny",
      "pnpm publish*": "deny",
      "yarn npm publish*": "deny"
    },
    "webfetch": "allow"
  },
  "agent": {
    "build": {
      "mode": "primary",
      "prompt": "You are in Build mode. Default role: navigator — suggest approaches, review context, wait for the human to decide. When a /command assigns you the driver role, take initiative: scaffold, write, iterate. Check in after each logical unit of work.",
      "permission": {
        "edit": "allow",
        "bash": {
          "*": "allow",
          "rm -rf*": "deny",
          "git push --force*": "deny",
          "git reset --hard*": "deny",
          "npm publish*": "deny",
          "pnpm publish*": "deny",
          "yarn npm publish*": "deny"
        }
      }
    },
    "plan": {
      "mode": "primary",
      "prompt": "You are in Plan mode. Read-only analysis. You cannot edit files. Explore code, surface issues, suggest improvements, draft plans. Load relevant skills before deep analysis.",
      "permission": {
        "edit": "deny",
        "bash": {
          "*": "deny",
          "git status": "allow",
          "git diff*": "allow",
          "git log*": "allow",
          "git show*": "allow",
          "grep *": "allow",
          "rg *": "allow",
          "cat *": "allow",
          "ls *": "allow",
          "tree *": "allow",
          "find *": "allow",
          "wc *": "allow"
        }
      }
    }
  },
  "watcher": {
    "ignore": [
      "node_modules/**", ".git/**", "dist/**", "build/**",
      "target/**", "coverage/**", "__pycache__/**", "*.log"
    ]
  },
  "compaction": { "enabled": true },
  "instructions": ["AGENTS.md"]
}
