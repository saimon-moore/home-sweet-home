{{- $buildHelixFromSource := false -}}
{{- if hasKey . "build_helix_from_source" }}{{- $buildHelixFromSource = .build_helix_from_source }}{{- end }}
{{- if and .develop $buildHelixFromSource -}}
#!/usr/bin/env bash
set -euo pipefail

if ! command -v cargo >/dev/null 2>&1; then
	exit 0
fi

for candidate in \
	{{ joinPath .chezmoi.sourceDir ".." "bootstrap" "host" "helix-install.sh" | quote }} \
	{{ joinPath .chezmoi.sourceDir "bootstrap" "host" "helix-install.sh" | quote }}; do
	if [[ -f "$candidate" ]]; then
		exec bash "$candidate" --install-only
	fi
done

echo "Error: could not locate bootstrap/host/helix-install.sh from chezmoi source path {{ .chezmoi.sourceDir }}." >&2
exit 1
{{- end }}
